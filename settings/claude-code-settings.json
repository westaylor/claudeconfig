{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(**)",
      "MultiEdit(**)",
      "Write(**)",
      "Glob",
      "Grep",
      "LS",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(pwd)",
      "Bash(find *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(grep *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(sort *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(diff *)",
      "Bash(which *)",
      "Bash(env)",
      "Bash(git init)",
      "Bash(git init *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(rm *)",
      "Bash(cargo *)",
      "Bash(rustc *)",
      "Bash(rustup *)",
      "Bash(docker *)",
      "WebFetch",
      "Read(~/.claude/plugins/**)",
      "mcp__plugin_context7_context7__*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Bash(rm ../*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(git reset --hard *)",
      "Bash(git push --force *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git push -f *)",
      "Bash(aws iam delete-*)",
      "Bash(npx cdk destroy *)",
      "Bash(tofu destroy *)",
      "Bash(tofu apply -destroy *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "autoMemoryEnabled": true,
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "APP=\"${TERM_PROGRAM:-Terminal}\"; case \"$APP\" in Apple_Terminal) APP=Terminal;; iTerm.app) APP=iTerm;; vscode) APP=\"Visual Studio Code\";; esac; osascript -e \"tell application \\\"$APP\\\" to display notification \\\"Claude needs permission\\\" with title \\\"Claude Code\\\"\""
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "APP=\"${TERM_PROGRAM:-Terminal}\"; case \"$APP\" in Apple_Terminal) APP=Terminal;; iTerm.app) APP=iTerm;; vscode) APP=\"Visual Studio Code\";; esac; osascript -e \"tell application \\\"$APP\\\" to display notification \\\"Claude is waiting for input\\\" with title \\\"Claude Code\\\"\""
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "APP=\"${TERM_PROGRAM:-Terminal}\"; case \"$APP\" in Apple_Terminal) APP=Terminal;; iTerm.app) APP=iTerm;; vscode) APP=\"Visual Studio Code\";; esac; osascript -e \"tell application \\\"$APP\\\" to display notification \\\"Claude has a question\\\" with title \\\"Claude Code\\\"\""
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [
      "docker"
    ],
    "network": {
      "allowUnixSockets": ["//var/run/docker.sock"]
    }
  }
}
